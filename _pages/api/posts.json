---
permalink: /api/posts.json
---
[
  {% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": "{{ post.date | date: '%Y-%m-%d' }}",
    "date_formatted": "{{ post.date | date: '%d %b %Y' }}",
    "category": {{ post.categories[0] | default: "" | jsonify }},
    "category_slug": "{{ post.categories[0] | slugify }}",
    "tags": [{% for tag in post.tags %}{{ tag | slugify | jsonify }}{% unless forloop.last %},{% endunless %}{% endfor %}],
    "tags_display": [{% for tag in post.tags %}{{ tag | jsonify }}{% unless forloop.last %},{% endunless %}{% endfor %}],
    "image": {{ post.image | default: "" | jsonify }},
    "excerpt": {% if post.excerpt %}{{ post.excerpt | strip_html | truncatewords: 20 | jsonify }}{% else %}{{ post.content | strip_html | truncatewords: 20 | jsonify }}{% endif %}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
